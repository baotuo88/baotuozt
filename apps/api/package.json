{
  "name": "@baotuo/api",
  "private": true,
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --env-file=.env src/server.ts",
    "dev:worker": "tsx --env-file=.env src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx --env-file=.env src/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.821.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.58.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
