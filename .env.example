# Compose
COMPOSE_PROJECT_NAME=baotuo

# Images / ports
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7-alpine
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3000
WEB_PORT=3001

# Postgres bootstrap
POSTGRES_DB=baotuo
POSTGRES_USER=baotuo
POSTGRES_PASSWORD=baotuo

# Runtime (api/worker)
NODE_ENV=production
DATABASE_URL=postgresql://baotuo:baotuo@postgres:5432/baotuo
REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

API_HOST=0.0.0.0
API_JSON_LIMIT=20mb

LOCAL_UPLOAD_DIR=/app/apps/api/storage
LOCAL_UPLOAD_URL_PREFIX=/uploaded
LOCAL_UPLOAD_PUBLIC_BASE_URL=http://localhost:3000/uploaded

WORKER_CONCURRENCY=5
WORKER_THUMBNAIL_WIDTH=480

IMAGE_MODEL_STABLE=gpt-image-1
IMAGE_MODEL_NEW=gpt-image-1
IMAGE_REQUEST_TIMEOUT_MS=30000
IMAGE_RETRIES_PER_PROVIDER=3
USE_MODEL_PROVIDER_ROUTER=true

RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_DAY=50
ABUSE_REGISTER_PER_IP_PER_DAY=3
ABUSE_ABNORMAL_PER_MINUTE=20
ABUSE_ABNORMAL_PER_FIVE_MINUTES=60

# Optional S3
S3_ENABLED=false
S3_REGION=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_BASE_URL=

# Web build/runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_IMAGE_HOSTS=picsum.photos
